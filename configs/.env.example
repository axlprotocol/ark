# ARK Environment Variables
# Copy to .env and fill in your values

# Secrets
WEBUI_SECRET_KEY=change-me-random-string
N8N_PASSWORD=change-me-n8n-password
GRAFANA_PASSWORD=change-me-grafana-password

# LiteLLM
LITELLM_MASTER_KEY=sk-change-me-generate-with-openssl-rand

# Domain (for Nginx/Caddy)
DOMAIN=yourdomain.com

# GPU
NVIDIA_VISIBLE_DEVICES=all
